---
const { name, class: className = "", size = 24 } = Astro.props;
---

<svg
  aria-hidden="true"
  class={className}
  fill="none"
  focusable="false"
  height={size}
  viewBox="0 0 24 24"
  width={size}
  xmlns="http://www.w3.org/2000/svg"
>
  {name === "arrow_forward" && <path d="M4 11h12.17l-5.59-5.59L12 4l8 8-8 8-1.41-1.41L16.17 13H4z" fill="currentColor" />}
  {name === "alternate_email" && (
    <>
      <path d="M4 6h16v12H4z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
      <path d="M4 8.5 12 13l8-4.5" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
    </>
  )}
  {name === "call" && (
    <path
      d="M6.62 10.79a15.91 15.91 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.02-.24c1.12.37 2.33.57 3.57.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.95 21 3 13.05 3 3a1 1 0 0 1 1-1h3.49a1 1 0 0 1 1 1c0 1.24.2 2.45.57 3.57.12.33.04.7-.24 1.02l-2.2 2.2Z"
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="1.8"
    />
  )}
  {name === "share" && (
    <>
      <circle cx="18" cy="5" r="2" stroke="currentColor" stroke-width="1.8" />
      <circle cx="6" cy="12" r="2" stroke="currentColor" stroke-width="1.8" />
      <circle cx="18" cy="19" r="2" stroke="currentColor" stroke-width="1.8" />
      <path d="M7.7 11.1 16.3 6.9M7.7 12.9l8.6 4.2" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
    </>
  )}
  {name === "hub" && (
    <>
      <circle cx="12" cy="12" r="2.1" stroke="currentColor" stroke-width="1.8" />
      <circle cx="5" cy="5" r="2" stroke="currentColor" stroke-width="1.8" />
      <circle cx="19" cy="5" r="2" stroke="currentColor" stroke-width="1.8" />
      <circle cx="19" cy="19" r="2" stroke="currentColor" stroke-width="1.8" />
      <path d="M6.4 6.4 10.5 10.5M17.6 6.4 13.5 10.5M13.5 13.5 17.6 17.6" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
    </>
  )}
  {name === "link" && (
    <path
      d="M10.5 13.5 13.5 10.5M8.5 15.5l-1.6 1.6a3 3 0 1 1-4.2-4.2l3.3-3.3a3 3 0 0 1 4.2 0m5.2 0a3 3 0 0 1 0 4.2l-3.3 3.3a3 3 0 0 1-4.2 0"
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="1.8"
    />
  )}
  {name === "architecture" && (
    <>
      <path d="M4 20h16" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
      <path d="M6 20V9l6-4 6 4v11" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
      <path d="M9 20v-5h6v5" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
    </>
  )}
  {name === "psychology" && (
    <path
      d="M12 3a6.5 6.5 0 0 0-4.8 10.9V16a2 2 0 0 0 2 2h1v-2.2a1 1 0 0 1 1-1h1.6a1 1 0 0 1 1 1V18h1a2 2 0 0 0 2-2v-2.1A6.5 6.5 0 0 0 12 3Zm-1 16h2"
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="1.8"
    />
  )}
  {name === "workspace_premium" && (
    <>
      <path d="M12 3 14.8 6.8 19.5 7.4 16 10.7 16.8 15.4 12 13 7.2 15.4 8 10.7 4.5 7.4 9.2 6.8 12 3Z" stroke="currentColor" stroke-linejoin="round" stroke-width="1.8" />
      <path d="M12 13v6" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
    </>
  )}
  {name === "check_circle" && (
    <>
      <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8" />
      <path d="m8.5 12.5 2.6 2.6 4.7-5.7" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
    </>
  )}
  {name === "flight_takeoff" && (
    <path
      d="M2 21 21 12 2 3l2.3 6.7L13 12l-8.7 2.3L2 21Zm0 0 8.2-8.2"
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="1.8"
    />
  )}
</svg>
