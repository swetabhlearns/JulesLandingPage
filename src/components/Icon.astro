      <circle cx="12" cy="16" r="2" stroke="currentColor" stroke-width="1.8" />
    </>
  )}
  {name === "package" && (
    <>
      <path d="M5.5 8 12 4.5 18.5 8 12 11.5 5.5 8Z" stroke="currentColor" stroke-linejoin="round" stroke-width="1.8" />
      <path d="M5.5 8v8L12 19.5 18.5 16V8" stroke="currentColor" stroke-linejoin="round" stroke-width="1.8" />
      <path d="M12 11.5v8" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
    </>
  )}
  {name === "moped" && (
    <>
      <circle cx="7.5" cy="17" r="2.2" stroke="currentColor" stroke-width="1.8" />
      <circle cx="16.5" cy="17" r="2.2" stroke="currentColor" stroke-width="1.8" />
      <path d="M8.9 16.3 11.4 10h3.4l1.2 2.2h3" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
      <path d="M9.4 13h3.3l1.2 3.3" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
      <path d="M6.7 10.7h2.1l1.3 2.3" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
    </>
  )}
  {name === "construction" && (
    <>
      <path d="M10.2 4.5 6.7 8l9.3 9.3 3.5-3.5-9.3-9.3Z" stroke="currentColor" stroke-linejoin="round" stroke-width="1.8" />
      <path d="m5 19 3.5-3.5" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
      <path d="M16.8 7.2 19 5" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
    </>
  )}
  {name === "memory" && (
    <>
      <rect x="6" y="6" width="12" height="12" rx="2" stroke="currentColor" stroke-width="1.8" />
      <path d="M9 4v2M12 4v2M15 4v2M9 18v2M12 18v2M15 18v2M4 9h2M4 12h2M4 15h2M18 9h2M18 12h2M18 15h2" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
      <rect x="9" y="9" width="6" height="6" rx="1.2" stroke="currentColor" stroke-width="1.8" />
    </>
  )}
  {name === "location_searching" && (
    <>
      <path d="M12 21s5.2-5 5.2-10.1A5.2 5.2 0 0 0 12 5.7a5.2 5.2 0 0 0-5.2 5.2C6.8 16 12 21 12 21Z" stroke="currentColor" stroke-linejoin="round" stroke-width="1.8" />
      <circle cx="12" cy="11" r="1.9" stroke="currentColor" stroke-width="1.8" />
      <path d="M19 19l2 2" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
    </>
  )}
  {name === "shield_with_heart" && (
    <>
      <path d="M12 3.5 19 6v5.2c0 4.7-2.9 8.3-7 9.8-4.1-1.5-7-5.1-7-9.8V6l7-2.5Z" stroke="currentColor" stroke-linejoin="round" stroke-width="1.8" />
      <path d="M12 16.2 8.8 13a2.1 2.1 0 0 1 3.2-2.6A2.1 2.1 0 0 1 15.2 13L12 16.2Z" fill="currentColor" />
    </>
  )}
  {name === "encrypted" && (
    <>
      <rect x="5.5" y="10" width="13" height="9" rx="2" stroke="currentColor" stroke-width="1.8" />
      <path d="M8.5 10V8.5a3.5 3.5 0 0 1 7 0V10" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
      <path d="M12 13.2v2.4" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
      <circle cx="12" cy="13.2" r="1" stroke="currentColor" stroke-width="1.8" />
    </>
  )}
</svg>
