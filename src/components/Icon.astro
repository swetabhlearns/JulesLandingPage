    <>
      <circle cx="12" cy="12" r="8.5" stroke="currentColor" stroke-width="1.8" />
      <path d="M12 7.5V12l3 1.8" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
      <path d="M7.5 4.5v3M16.5 4.5v3" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
    </>
  )}
  {name === "precision_manufacturing" && (
    <>
      <circle cx="12" cy="12" r="3.1" stroke="currentColor" stroke-width="1.8" />
      <path d="M12 3.5v2.2M12 18.3v2.2M3.5 12h2.2M18.3 12h2.2" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
      <path d="m5.8 5.8 1.6 1.6m9.2 9.2 1.6 1.6M5.8 18.2l1.6-1.6m9.2-9.2 1.6-1.6" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
    </>
  )}
  {name === "settings_input_component" && (
    <>
      <rect x="4" y="4" width="4" height="4" rx="1" stroke="currentColor" stroke-width="1.8" />
