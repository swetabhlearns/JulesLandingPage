---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteNav from "../components/SiteNav.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<BaseLayout
  title="Contact Us | Samridhi Informatics"
  bodyClass="bg-surface text-on-surface font-body selection:bg-primary-container selection:text-white"
  htmlClass="light"
>
  <script slot="head" is:inline id="tailwind-config">
    window.tailwind = window.tailwind || {};
    window.tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "inverse-on-surface": "#f0f1f2",
            surface: "#f8f9fa",
            outline: "#757685",
            secondary: "#515d84",
            "on-secondary-container": "#4c587f",
            "on-tertiary-fixed": "#00105b",
            "on-secondary-fixed-variant": "#39456b",
            "inverse-primary": "#bac3ff",
            "tertiary-fixed-dim": "#bac3ff",
            "tertiary-container": "#002ec7",
            "primary-container": "#1a36b0",
            "on-surface": "#191c1d",
            "surface-container-highest": "#e1e3e4",
            "secondary-fixed-dim": "#b9c5f2",
            "outline-variant": "#c5c5d6",
            "on-secondary-fixed": "#0b1a3d",
            "on-primary-fixed-variant": "#1c38b1",
            "error-container": "#ffdad6",
            "on-primary-container": "#a0aeff",
            "on-background": "#191c1d",
            background: "#f8f9fa",
            "on-tertiary-fixed-variant": "#002eca",
            tertiary: "#001e8e",
            "surface-container-lowest": "#ffffff",
            primary: "#001f8b",
            "surface-bright": "#f8f9fa",
            "surface-container": "#edeeef",
            "on-primary-fixed": "#00115a",
            "on-primary": "#ffffff",
            "primary-fixed": "#dee0ff",
            "on-error": "#ffffff",
            "on-tertiary": "#ffffff",
            "surface-container-high": "#e7e8e9",
            "on-error-container": "#93000a",
            "secondary-fixed": "#dbe1ff",
            "on-tertiary-container": "#a1aeff",
            error: "#ba1a1a",
            "primary-fixed-dim": "#bac3ff",
            "surface-variant": "#e1e3e4",
            "surface-tint": "#3a52ca",
            "inverse-surface": "#2e3132",
            "tertiary-fixed": "#dee0ff",
            "on-surface-variant": "#444654",
            "surface-container-low": "#f3f4f5",
            "secondary-container": "#c4d0fd",
            "on-secondary": "#ffffff",
            "surface-dim": "#d9dadb",
          },
          borderRadius: {
            DEFAULT: "0.125rem",
            lg: "0.25rem",
            xl: "0.5rem",
            full: "9999px",
          },
          fontFamily: {
            headline: ["Manrope"],
            body: ["Manrope"],
            label: ["Manrope"],
          },
        },
      },
    };
  </script>
  <style slot="head">
    * {
      font-family: "Manrope", sans-serif !important;
      font-weight: 400 !important;
    }

    .font-medium,
    .font-semibold,
    .font-bold,
    .font-extrabold,
    h1,
    h2,
    h3,
    h4,
    b,
    strong,
    button,
    nav a {
      font-weight: 500 !important;
    }

    .material-symbols-outlined {
      font-variation-settings: "FILL" 0, "wght" 200, "GRAD" 0, "opsz" 24;
      vertical-align: middle;
      font-family: "Material Symbols Outlined" !important;
    }

    .glass-nav {
      background: rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
    }

    input:focus,
    textarea:focus {
      outline: none;
      box-shadow: none;
    }

    .line-accent {
      width: 24px;
      height: 2px;
      background-color: #001f8b;
    }

    .hero-gradient-overlay {
      background: linear-gradient(to right, rgba(248, 249, 250, 0.8) 0%, rgba(248, 249, 250, 0.3) 50%, rgba(248, 249, 250, 0) 100%);
    }

    .text-shadow-sm {
      text-shadow: 0 1px 2px rgba(255, 255, 255, 0.8);
    }
  </style>
  <SiteNav />

  <main>
    <div class="relative h-screen flex items-center overflow-hidden py-24 md:py-32">
      <div class="absolute inset-0 z-0">
        <img
          alt="Professional architectural skyscraper background"
          class="w-full h-full object-cover"
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuC6TvnRD72wb4iiB_g6tUl3pnNQnRZSCbRq0sPf6t9z-WHN1hcOh3wWM8jj0e31-cMD74D25PcKdecoJbO0LMwjEYNP4Hstn3uZC8avXC_UYg8V89LmGgV_0-PXbEpPyLbHf3LVOeqrGlpBB_Hp3qasWKQ4Ev18Q3mfbu52Tz-o7OOMJAtOM8LHiq6IP4LHOk-I16YwVeWA-CZ2xdCd7UELNKooYU44VWKgAurriz3ZKJSVc3nIR3lhKUpRQ_tP05D3Okg8Pzqckrk7"
        />
        <div class="absolute inset-0 hero-gradient-overlay"></div>
      </div>

      <section class="relative z-10 max-w-7xl mx-auto px-8 w-full">
        <div class="line-accent mb-6"></div>
        <h1 class="font-headline text-6xl md:text-8xl font-medium tracking-tighter text-primary mb-8 max-w-4xl leading-[0.9] text-shadow-sm">
          Talk to a team built for delivery.
        </h1>
        <p class="text-secondary text-xl md:text-2xl font-light max-w-2xl leading-relaxed text-shadow-sm">
          We welcome inquiries, partnerships, and project discussions across tactical, technical, and deployment needs.
        </p>
      </section>
    </div>

    <section id="contact-form" class="max-w-7xl mx-auto px-8 grid grid-cols-1 lg:grid-cols-12 gap-16 items-start mb-32">
      <div class="lg:col-span-7 bg-surface-container-low p-10 md:p-16 rounded-lg">
        <h2 class="font-headline text-3xl font-medium text-primary mb-12">Inquiry Brief</h2>
        <form class="space-y-10">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
            <div class="relative group">
              <label class="block text-sm font-medium text-on-surface-variant mb-2 font-label" for="full-name">Full Name</label>
              <input id="full-name" class="w-full bg-surface-container-high px-0 py-3 border-b border-outline-variant focus:border-primary transition-all duration-500 bg-transparent placeholder:text-outline-variant/50" placeholder="John Doe" type="text" />
            </div>
            <div class="relative group">
              <label class="block text-sm font-medium text-on-surface-variant mb-2 font-label" for="work-email">Work Email</label>
              <input id="work-email" class="w-full bg-surface-container-high px-0 py-3 border-b border-outline-variant focus:border-primary transition-all duration-500 bg-transparent placeholder:text-outline-variant/50" placeholder="john@enterprise.com" type="email" />
            </div>
          </div>
          <div class="relative group">
            <label class="block text-sm font-medium text-on-surface-variant mb-2 font-label" for="subject">Subject</label>
            <input id="subject" class="w-full bg-surface-container-high px-0 py-3 border-b border-outline-variant focus:border-primary transition-all duration-500 bg-transparent placeholder:text-outline-variant/50" placeholder="Digital Transformation Strategy" type="text" />
          </div>
          <div class="relative group">
            <label class="block text-sm font-medium text-on-surface-variant mb-2 font-label" for="message">Message</label>
            <textarea id="message" class="w-full bg-surface-container-high px-0 py-3 border-b border-outline-variant focus:border-primary transition-all duration-500 bg-transparent placeholder:text-outline-variant/50 resize-none" placeholder="Tell us about your objectives..." rows="4"></textarea>
          </div>
          <button class="group flex items-center gap-4 bg-primary text-on-primary px-8 py-4 rounded-md font-medium transition-all duration-300 hover:shadow-[0_12px_32px_rgba(0,31,139,0.15)] active:scale-95" type="submit">
            Send Inquiry
            <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
          </button>
        </form>
      </div>

      <div class="lg:col-span-5 lg:pl-12 lg:pt-16 space-y-16">
        <div>
          <h3 class="font-headline text-sm font-medium tracking-[0.2em] text-primary uppercase mb-8">Contact Nodes</h3>
          <div class="space-y-8">
            <div class="flex items-start gap-6">
              <span class="material-symbols-outlined text-primary mt-1">alternate_email</span>
              <div>
                <p class="text-xs font-medium text-outline uppercase tracking-widest mb-1">Electronic Mail</p>
                <a class="text-xl font-medium text-on-surface hover:text-primary transition-colors" href="mailto:info.tactical@bktcorp.com">info.tactical@bktcorp.com</a>
              </div>
            </div>
            <div class="flex items-start gap-6">
              <span class="material-symbols-outlined text-primary mt-1">call</span>
              <div>
                <p class="text-xs font-medium text-outline uppercase tracking-widest mb-1">Direct Line</p>
                <a class="text-xl font-medium text-on-surface hover:text-primary transition-colors" href="tel:+18005550199">+1 (800) 555-0199</a>
              </div>
            </div>
          </div>
        </div>

        <div>
          <h3 class="font-headline text-sm font-medium tracking-[0.2em] text-primary uppercase mb-8">Social Ecosystem</h3>
          <div class="flex flex-wrap gap-4">
            <a class="w-12 h-12 flex items-center justify-center bg-surface-container-high rounded-full hover:bg-primary hover:text-white transition-all" href="#">
              <span class="material-symbols-outlined">share</span>
            </a>
            <a class="w-12 h-12 flex items-center justify-center bg-surface-container-high rounded-full hover:bg-primary hover:text-white transition-all" href="#">
              <span class="material-symbols-outlined">hub</span>
            </a>
            <a class="w-12 h-12 flex items-center justify-center bg-surface-container-high rounded-full hover:bg-primary hover:text-white transition-all" href="#">
              <span class="material-symbols-outlined">link</span>
            </a>
          </div>
        </div>

      </div>
    </section>

    <section class="max-w-7xl mx-auto px-8 mb-32">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-20 items-start">
        <div>
          <div class="line-accent mb-4"></div>
          <span class="font-headline text-sm font-medium tracking-[0.2em] text-primary uppercase block mb-4">How We Support You</span>
          <h2 class="font-headline text-4xl md:text-5xl font-medium text-primary tracking-tight max-w-xl">Tailored support for tactical, technical, and deployment requirements.</h2>
          <p class="text-secondary max-w-xl mt-6 font-light leading-relaxed">
            BKT Tactical Solutions provides practical execution support for organizations looking for reliable drone, tactical, and project delivery capabilities.
          </p>

          <div class="space-y-4 mt-10">
            <div class="group bg-surface-container-lowest p-6 rounded-lg border border-surface-container-high transition-all duration-300 hover:bg-primary hover:border-primary hover:shadow-[0_16px_40px_rgba(26,54,176,0.15)]">
              <h3 class="font-headline text-lg font-medium text-on-surface mb-2 transition-colors duration-300 group-hover:text-white">Mission-specific drone solutions</h3>
              <p class="text-on-surface-variant text-sm leading-relaxed transition-colors duration-300 group-hover:text-white/80">Custom-built aerial solutions aligned with operational goals, safety, and deployment needs.</p>
            </div>
            <div class="group bg-surface-container-lowest p-6 rounded-lg border border-surface-container-high transition-all duration-300 hover:bg-primary hover:border-primary hover:shadow-[0_16px_40px_rgba(26,54,176,0.15)]">
              <h3 class="font-headline text-lg font-medium text-on-surface mb-2 transition-colors duration-300 group-hover:text-white">Tactical project support</h3>
              <p class="text-on-surface-variant text-sm leading-relaxed transition-colors duration-300 group-hover:text-white/80">End-to-end assistance for tactical programs, field execution, and time-sensitive workstreams.</p>
            </div>
            <div class="group bg-surface-container-lowest p-6 rounded-lg border border-surface-container-high transition-all duration-300 hover:bg-primary hover:border-primary hover:shadow-[0_16px_40px_rgba(26,54,176,0.15)]">
              <h3 class="font-headline text-lg font-medium text-on-surface mb-2 transition-colors duration-300 group-hover:text-white">Vendor and execution coordination</h3>
              <p class="text-on-surface-variant text-sm leading-relaxed transition-colors duration-300 group-hover:text-white/80">Structured coordination for vendors, delivery partners, and on-ground execution teams.</p>
            </div>
            <div class="group bg-surface-container-lowest p-6 rounded-lg border border-surface-container-high transition-all duration-300 hover:bg-primary hover:border-primary hover:shadow-[0_16px_40px_rgba(26,54,176,0.15)]">
              <h3 class="font-headline text-lg font-medium text-on-surface mb-2 transition-colors duration-300 group-hover:text-white">Design-to-deployment delivery</h3>
              <p class="text-on-surface-variant text-sm leading-relaxed transition-colors duration-300 group-hover:text-white/80">From planning and solution design to implementation and deployment, we support the full lifecycle.</p>
            </div>
          </div>
        </div>

        <div>
          <div class="line-accent mb-4"></div>
          <span class="font-headline text-sm font-medium tracking-[0.2em] text-primary uppercase block mb-4">Why Connect With Us</span>
          <h2 class="font-headline text-4xl md:text-5xl font-medium text-primary tracking-tight max-w-xl">A responsive partner built for precision, trust, and long-term value.</h2>
          <p class="text-secondary max-w-xl mt-6 font-light leading-relaxed">
            Whether you need a custom solution or ongoing operational support, our team is structured to respond quickly and deliver with consistency.
          </p>

          <div class="space-y-4 mt-10">
            <div class="group bg-surface-container-lowest p-6 rounded-lg border border-surface-container-high transition-all duration-300 hover:bg-primary hover:border-primary hover:shadow-[0_16px_40px_rgba(26,54,176,0.15)]">
              <h3 class="font-headline text-lg font-medium text-on-surface mb-2 transition-colors duration-300 group-hover:text-white">Tailored solutions</h3>
              <p class="text-on-surface-variant text-sm leading-relaxed transition-colors duration-300 group-hover:text-white/80">Built around your exact operational requirements and project objectives.</p>
            </div>
            <div class="group bg-surface-container-lowest p-6 rounded-lg border border-surface-container-high transition-all duration-300 hover:bg-primary hover:border-primary hover:shadow-[0_16px_40px_rgba(26,54,176,0.15)]">
              <h3 class="font-headline text-lg font-medium text-on-surface mb-2 transition-colors duration-300 group-hover:text-white">Responsive communication</h3>
              <p class="text-on-surface-variant text-sm leading-relaxed transition-colors duration-300 group-hover:text-white/80">Professional, timely engagement from a team that values clarity and speed.</p>
            </div>
            <div class="group bg-surface-container-lowest p-6 rounded-lg border border-surface-container-high transition-all duration-300 hover:bg-primary hover:border-primary hover:shadow-[0_16px_40px_rgba(26,54,176,0.15)]">
              <h3 class="font-headline text-lg font-medium text-on-surface mb-2 transition-colors duration-300 group-hover:text-white">Execution-focused support</h3>
              <p class="text-on-surface-variant text-sm leading-relaxed transition-colors duration-300 group-hover:text-white/80">Practical on-ground expertise designed to keep delivery moving efficiently.</p>
            </div>
            <div class="group bg-surface-container-lowest p-6 rounded-lg border border-surface-container-high transition-all duration-300 hover:bg-primary hover:border-primary hover:shadow-[0_16px_40px_rgba(26,54,176,0.15)]">
              <h3 class="font-headline text-lg font-medium text-on-surface mb-2 transition-colors duration-300 group-hover:text-white">Reliable partnership</h3>
              <p class="text-on-surface-variant text-sm leading-relaxed transition-colors duration-300 group-hover:text-white/80">Long-term collaboration built on trust, performance, and shared outcomes.</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
