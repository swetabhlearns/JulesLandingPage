---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteNav from "../components/SiteNav.astro";
import SiteFooter from "../components/SiteFooter.astro";
import Icon from "../components/Icon.astro";
import ResponsiveImage from "../components/ResponsiveImage.astro";
import { careersSchema } from "../lib/schema";
---

<BaseLayout
  title="Careers at BKT Tactical | Drone & Defence Tech Jobs India"
  description="Explore UAV engineering, embedded systems, manufacturing, operations, supply chain, and field support career paths at BKT Tactical Solutions in India."
  schema={careersSchema()}
  bodyClass="bg-surface text-on-surface antialiased"
>
  <SiteNav />

  <main>
    <section class="relative min-h-[86svh] flex items-center overflow-hidden reveal py-24 md:py-48">
      <div class="absolute inset-0 z-0">
        <ResponsiveImage
          alt="Engineering team reviewing UAV hardware and flight operations planning"
          class="w-full h-full object-cover opacity-90 grayscale-[20%]"
          fetchpriority="high"
          loading="eager"
          sizes="100vw"
          stem="/images/remote/15-82b6885bd5"
        />
        <div class="absolute inset-0 hero-gradient-overlay"></div>
      </div>

      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 md:px-8 w-full">
        <div class="max-w-3xl">
          <div class="w-12 h-1 bg-primary mb-8"></div>
          <h1 class="font-headline text-4xl sm:text-5xl md:text-7xl font-medium text-white tracking-tight leading-[1.1] mb-6 md:mb-8 text-shadow-sm">
            Build drone and defence technology in India.
          </h1>
          <p class="text-base sm:text-lg md:text-xl text-slate-200 max-w-xl font-body mb-8 md:mb-10 leading-relaxed text-shadow-sm">
            BKT Tactical is shaping UAV capability across engineering, embedded systems, manufacturing, operations, supply chain, and field deployment.
          </p>
          <a class="bg-primary text-on-primary px-8 py-4 rounded-sm font-medium hover:bg-primary-container transition-all w-full sm:w-auto text-center inline-flex justify-center" href="#focus-areas">Explore Career Areas</a>
        </div>
      </div>
    </section>

    <section id="focus-areas" class="bg-surface-container py-20 md:py-32 px-4 sm:px-6 md:px-12 reveal">
      <div class="max-w-7xl mx-auto">
        <div class="mb-16">
          <div class="w-8 h-1 bg-primary mb-6"></div>
          <h2 class="text-4xl md:text-5xl font-medium text-on-surface mb-4 tracking-tight">Career areas aligned with UAV execution.</h2>
          <p class="text-on-surface-variant text-lg font-medium max-w-3xl">The roles below represent the operating disciplines BKT Tactical expects to hire for as product development, manufacturing, and deployment programs mature.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-slate-200 border border-slate-200">
          {[
            ["UAV Engineering", "Airframe, propulsion, payload integration, and flight-system engineering for heavy payload drone platforms.", "precision_manufacturing"],
            ["Embedded Systems", "Flight electronics, datalink planning, sensor integration, and reliability-focused control systems.", "memory"],
            ["Manufacturing & QA", "Production planning, assembly workflows, inspection, maintainability, and quality assurance.", "fact_check"],
            ["Flight Operations", "Mission planning, test coordination, field procedures, and safety-focused deployment support.", "flight_takeoff"],
            ["Supply Chain", "Vendor coordination, component planning, logistics readiness, and local sourcing workflows.", "inventory_2"],
            ["Field Support", "On-ground deployment, customer coordination, maintenance support, and mission feedback loops.", "support_agent"],
          ].map(([title, body, icon]) => (
            <div class="bg-white p-6 sm:p-8 md:p-10 transition-all duration-300 hover:bg-[#1A36B0] group cursor-default">
              <Icon class="text-primary text-3xl mb-6 transition-colors duration-300 group-hover:text-white" name={icon} />
              <h3 class="text-2xl font-medium mb-4 transition-colors duration-300 group-hover:text-white">{title}</h3>
              <p class="text-on-surface-variant text-sm leading-relaxed font-medium transition-colors duration-300 group-hover:text-white/90">{body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-20 md:py-32 px-4 sm:px-6 md:px-12 bg-white reveal">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start">
          <div class="lg:col-span-5">
            <div class="w-12 h-1 bg-primary mb-6"></div>
            <h2 class="text-4xl md:text-5xl font-medium text-on-surface mb-6 tracking-tight">Open applications</h2>
            <p class="text-on-surface-variant text-lg leading-relaxed">
              Current hiring needs will be published when role details are verified. Candidates with relevant UAV, embedded, manufacturing, or field operations experience can still introduce themselves.
            </p>
          </div>
          <div class="lg:col-span-7 space-y-5">
            {[
              "UAV or aerospace engineering experience",
              "Embedded systems, electronics, or flight controller familiarity",
              "Manufacturing, quality, or supply chain execution",
              "Drone operations, mission planning, or field deployment experience",
            ].map((item) => (
              <div class="flex items-center gap-4 bg-surface-container p-5 rounded-sm">
                <Icon class="text-primary shrink-0" name="task_alt" />
                <span class="text-on-surface-variant">{item}</span>
              </div>
            ))}
            <a class="bg-primary text-white px-8 py-4 rounded-sm font-medium text-sm uppercase tracking-widest hover:opacity-90 transition-all inline-flex w-full sm:w-auto justify-center" href="/contact/">Contact Careers Team</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
