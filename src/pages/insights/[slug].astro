---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteNav from "../../components/SiteNav.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import Icon from "../../components/Icon.astro";
import { insights } from "../../lib/seo-data";
import { articleSchema } from "../../lib/schema";

export function getStaticPaths() {
  return insights.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
---

<BaseLayout
  title={`${article.title} | BKT Tactical`}
  description={article.description}
  canonical={`https://bkttactical.com${article.path}`}
  schema={articleSchema(article.slug)}
  bodyClass="bg-surface text-on-surface antialiased"
>
  <SiteNav />

  <main>
    <article>
      <section class="min-h-[72svh] flex items-center bg-slate-950 text-white py-28 md:py-40 reveal">
        <div class="px-4 sm:px-6 md:px-12 max-w-5xl mx-auto w-full">
          <div class="text-xs uppercase tracking-[0.35em] text-white/55 mb-6">{article.category}</div>
          <h1 class="text-4xl sm:text-5xl md:text-7xl font-medium tracking-tight leading-[1.08] mb-8">{article.title}</h1>
          <p class="text-lg md:text-2xl text-white/78 leading-relaxed max-w-3xl">{article.intro}</p>
        </div>
      </section>

      <section class="py-20 md:py-32 bg-white reveal">
        <div class="px-4 sm:px-6 md:px-12 max-w-4xl mx-auto">
          <div class="space-y-14">
            {article.sections.map((section) => (
              <section>
                <h2 class="text-3xl md:text-4xl font-medium tracking-tight mb-5">{section.heading}</h2>
                <p class="text-lg text-on-surface-variant leading-relaxed">{section.body}</p>
              </section>
            ))}
          </div>

          <div class="mt-20 border-t border-slate-100 pt-10 flex flex-col sm:flex-row gap-4 sm:items-center sm:justify-between">
            <a class="inline-flex items-center gap-3 text-primary font-medium" href="/insights/">
              <Icon name="arrow_back" size={18} />
              Back to insights
            </a>
            <a class="inline-flex items-center gap-3 bg-primary text-white px-7 py-4 rounded-sm font-medium" href="/contact/">
              Discuss UAV requirements
              <Icon name="arrow_forward" size={18} />
            </a>
          </div>
        </div>
      </section>
    </article>
  </main>

  <SiteFooter />
</BaseLayout>
