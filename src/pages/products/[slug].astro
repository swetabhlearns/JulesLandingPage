---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteNav from "../../components/SiteNav.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import Icon from "../../components/Icon.astro";
import { products } from "../../lib/seo-data";
import { productSchema } from "../../lib/schema";

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
---

<BaseLayout
  title={product.title}
  description={product.description}
  canonical={`https://bkttactical.com${product.path}`}
  schema={productSchema(product.slug)}
  bodyClass="bg-surface text-on-surface antialiased"
>
  <SiteNav />

  <main>
    <section class="min-h-[78svh] flex items-center bg-slate-950 text-white py-28 md:py-40 reveal">
      <div class="px-4 sm:px-6 md:px-12 max-w-7xl mx-auto w-full">
        <div class="max-w-4xl">
          <div class="text-xs uppercase tracking-[0.35em] text-white/55 mb-6">Trishul Series</div>
          <h1 class="text-4xl sm:text-5xl md:text-7xl font-medium tracking-tight leading-[1.08] mb-8">{product.name}</h1>
          <p class="text-lg md:text-2xl text-white/78 leading-relaxed max-w-3xl">{product.description}</p>
        </div>
      </div>
    </section>

    <section class="py-20 md:py-32 bg-white reveal">
      <div class="px-4 sm:px-6 md:px-12 max-w-7xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">
          <div class="lg:col-span-5">
            <h2 class="text-4xl md:text-5xl font-medium tracking-tight mb-8">Built for payload-led missions.</h2>
            <p class="text-lg text-on-surface-variant leading-relaxed">
              {product.shortName} is designed for teams evaluating heavy payload drones in India where lift capacity, flight stability, RTK navigation, and repeatable deployment workflows are central to the mission.
            </p>
          </div>
          <div class="lg:col-span-7 grid grid-cols-1 sm:grid-cols-3 gap-px bg-slate-200 border border-slate-200">
            <div class="bg-slate-50 p-8">
              <div class="text-xs uppercase tracking-[0.24em] text-primary mb-4">Payload</div>
              <div class="text-3xl font-medium">{product.payload}</div>
            </div>
            <div class="bg-slate-50 p-8">
              <div class="text-xs uppercase tracking-[0.24em] text-primary mb-4">Endurance</div>
              <div class="text-3xl font-medium">{product.endurance}</div>
            </div>
            <div class="bg-slate-50 p-8">
              <div class="text-xs uppercase tracking-[0.24em] text-primary mb-4">Airframe</div>
              <div class="text-xl font-medium leading-snug">{product.configuration}</div>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 mt-20">
          <div>
            <h2 class="text-3xl font-medium mb-8">Mission use cases</h2>
            <div class="space-y-4">
              {product.useCases.map((item) => (
                <div class="flex items-center gap-4 border border-slate-100 bg-slate-50 p-5 rounded-sm">
                  <Icon class="text-primary shrink-0" name="task_alt" size={22} />
                  <span class="text-on-surface-variant">{item}</span>
                </div>
              ))}
            </div>
          </div>
          <div>
            <h2 class="text-3xl font-medium mb-8">Platform features</h2>
            <div class="space-y-4">
              {product.features.map((item) => (
                <div class="flex items-center gap-4 border border-slate-100 bg-slate-50 p-5 rounded-sm">
                  <Icon class="text-primary shrink-0" name="settings" size={22} />
                  <span class="text-on-surface-variant">{item}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="mt-20 bg-primary text-white p-8 md:p-12 rounded-sm flex flex-col lg:flex-row lg:items-center justify-between gap-8" style="background-color: #1A36B0;">
          <div>
            <h2 class="text-3xl md:text-4xl font-medium mb-4">Discuss a {product.payload} UAV requirement.</h2>
            <p class="text-white/75 max-w-2xl">Share payload, route, operating environment, and mission constraints so the team can respond with the right platform direction.</p>
          </div>
          <a class="bg-white text-primary px-8 py-4 rounded-sm font-medium text-sm uppercase tracking-widest inline-flex justify-center" href="/contact/">Enquire Now</a>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
