---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteNav from "../../components/SiteNav.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import Icon from "../../components/Icon.astro";
import { products } from "../../lib/seo-data";
import { productsSchema } from "../../lib/schema";
---

<BaseLayout
  title="Heavy Payload UAV Products | BKT Tactical"
  description="Explore the Trishul Series heavy payload UAV platforms for 10kg, 16kg, and 30kg payload operations in India."
  schema={productsSchema()}
  bodyClass="bg-surface text-on-surface antialiased"
>
  <SiteNav />

  <main>
    <section class="min-h-[78svh] flex items-center bg-primary text-white py-28 md:py-40 reveal" style="background-color: #1A36B0;">
      <div class="px-4 sm:px-6 md:px-12 max-w-7xl mx-auto w-full">
        <div class="max-w-4xl">
          <div class="w-12 h-1 bg-white mb-8"></div>
          <h1 class="text-4xl sm:text-5xl md:text-7xl font-medium tracking-tight leading-[1.08] mb-8">Trishul Series heavy payload UAV platforms.</h1>
          <p class="text-lg md:text-2xl text-white/78 leading-relaxed max-w-3xl">
            Three UAV configurations for 10kg, 16kg, and 30kg payload missions across logistics, tactical deployment, emergency response, and field support.
          </p>
        </div>
      </div>
    </section>

    <section class="py-20 md:py-32 bg-white reveal">
      <div class="px-4 sm:px-6 md:px-12 max-w-7xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
          {products.map((product) => (
            <article class="border border-slate-100 bg-slate-50 rounded-sm p-8 md:p-10 hover-card-blue group transition-all duration-300">
              <div class="text-xs uppercase tracking-[0.28em] text-primary mb-6 group-hover:text-white/70">{product.payload} payload</div>
              <h2 class="text-3xl font-medium mb-4 group-hover:text-white">{product.shortName}</h2>
              <p class="text-on-surface-variant leading-relaxed mb-8 group-hover:text-white/82">{product.description}</p>
              <div class="space-y-4 mb-10 text-sm text-on-surface-variant group-hover:text-white/88">
                <p><span class="font-medium text-on-surface group-hover:text-white">Endurance:</span> {product.endurance}</p>
                <p><span class="font-medium text-on-surface group-hover:text-white">Configuration:</span> {product.configuration}</p>
              </div>
              <a class="inline-flex items-center gap-3 text-primary group-hover:text-white font-medium" href={product.path}>
                View platform
                <Icon class="transition-transform group-hover:translate-x-1" name="arrow_forward" size={18} />
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
