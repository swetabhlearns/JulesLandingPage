---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteNav from "../components/SiteNav.astro";
import SiteFooter from "../components/SiteFooter.astro";
import Icon from "../components/Icon.astro";
import { products, solutions } from "../lib/seo-data";
import { solutionsSchema } from "../lib/schema";
---

<BaseLayout
  title="Drone Logistics & Tactical UAV Solutions India | BKT Tactical"
  description="Explore UAV solutions for drone logistics, tactical surveillance, emergency response, precision agriculture, and field deployment in India."
  schema={solutionsSchema()}
  bodyClass="bg-surface text-on-surface antialiased"
>
  <SiteNav />

  <main>
    <section class="min-h-[78svh] flex items-center bg-primary text-white py-28 md:py-40 reveal" style="background-color: #1A36B0;">
      <div class="px-4 sm:px-6 md:px-12 max-w-7xl mx-auto w-full">
        <div class="max-w-4xl">
          <div class="w-12 h-1 bg-white mb-8"></div>
          <h1 class="text-4xl sm:text-5xl md:text-7xl font-medium tracking-tight leading-[1.08] mb-8">Drone logistics and tactical UAV solutions for India.</h1>
          <p class="text-lg md:text-2xl text-white/78 leading-relaxed max-w-3xl">
            BKT Tactical supports heavy payload UAV missions across logistics, surveillance, emergency response, agriculture, and field deployment workflows.
          </p>
        </div>
      </div>
    </section>

    <section class="py-20 md:py-32 bg-white reveal">
      <div class="px-4 sm:px-6 md:px-12 max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {solutions.map((solution, index) => (
            <article class="border border-slate-100 bg-slate-50 rounded-sm p-8 md:p-10 hover-card-blue group transition-all duration-300">
              <div class="text-xs uppercase tracking-[0.28em] text-primary mb-6 group-hover:text-white/70">{String(index + 1).padStart(2, "0")}</div>
              <h2 class="text-3xl font-medium mb-5 group-hover:text-white">{solution.name}</h2>
              <p class="text-on-surface-variant leading-relaxed group-hover:text-white/82">{solution.description}</p>
            </article>
          ))}
        </div>

        <div class="mt-20 border-t border-slate-100 pt-16">
          <h2 class="text-4xl md:text-5xl font-medium tracking-tight mb-10">Match the UAV to the operating requirement.</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {products.map((product) => (
              <a class="block border border-slate-100 bg-white p-7 rounded-sm hover:bg-primary hover:text-white transition-colors group" href={product.path}>
                <div class="flex items-center justify-between gap-4 mb-4">
                  <h3 class="text-2xl font-medium">{product.shortName}</h3>
                  <Icon class="text-primary group-hover:text-white transition-colors" name="arrow_forward" />
                </div>
                <p class="text-sm text-on-surface-variant group-hover:text-white/75">{product.payload} payload, {product.endurance} endurance.</p>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
