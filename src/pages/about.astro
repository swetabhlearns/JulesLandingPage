---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import aboutHeroImage from "../assets/about-hero-bkt-drone.png";
import SiteNav from "../components/SiteNav.astro";
import SiteFooter from "../components/SiteFooter.astro";
import Icon from "../components/Icon.astro";
import ResponsiveImage from "../components/ResponsiveImage.astro";
import { aboutSchema } from "../lib/schema";
---

<BaseLayout
  title="About Us | BKT Tactical Solutions"
  description="Learn about BKT Tactical Solutions Private Limited, including its mission, vision, evolution, and leadership in tactical and drone solutions."
  canonical="https://bkttactical.com/about"
  schema={aboutSchema()}
  bodyClass="bg-surface text-on-surface font-body selection:bg-primary-container selection:text-white"
  htmlClass="light"
>
  <SiteNav />
    <main>
      <section class="relative min-h-[100svh] md:h-screen flex items-center overflow-hidden py-20 md:py-32">
        <div class="absolute inset-0 z-0">
          <Image
            alt="Industrial drone flying over a mountain landscape with tactical operator"
            class="w-full h-full object-cover"
            loading="eager"
            priority
            sizes="100vw"
            src={aboutHeroImage}
            widths={[480, 960, 1440]}
          />
          <div class="absolute inset-0 hero-gradient-overlay"></div>
        </div>

        <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 md:px-8 w-full">
          <div class="max-w-3xl">
            <div class="w-12 h-1 bg-primary mb-8"></div>
            <h1 class="font-headline text-4xl sm:text-5xl md:text-7xl font-medium text-white tracking-tight leading-[1.1] mb-6 md:mb-8 text-shadow-sm">
              Tactical solutions shaped for performance.
            </h1>
            <p class="text-base sm:text-lg md:text-xl text-slate-200 max-w-xl font-body mb-8 md:mb-10 leading-relaxed text-shadow-sm">
              BKT Tactical Solutions Private Limited combines advanced technology, indigenous capabilities, and responsible operations to deliver measurable outcomes.
            </p>
          </div>
        </div>
      </section>

      <section class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8 mb-16 md:mb-24">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-24 mt-12 md:mt-24">
          <div class="space-y-6 bg-surface-container-lowest p-6 sm:p-8 md:p-10 rounded-lg transition-all duration-500 hover:bg-primary group">
            <span class="text-primary font-headline font-medium tracking-widest text-sm uppercase group-hover:text-white/80 transition-colors">Our Mission</span>
            <h2 class="text-4xl font-headline font-medium text-on-surface group-hover:text-white transition-colors">Reliable execution through advanced technology.</h2>
            <p class="text-on-surface-variant leading-relaxed group-hover:text-white/75 transition-colors">We deliver high-quality, reliable, and scalable tactical and drone solutions through innovation-led execution, indigenous capability, sustainable operations, and long-term partnerships built on trust and performance.</p>
          </div>
          <div class="space-y-6 bg-surface-container-lowest p-6 sm:p-8 md:p-10 rounded-lg transition-all duration-500 hover:bg-primary group">
            <span class="text-primary font-headline font-medium tracking-widest text-sm uppercase group-hover:text-white/80 transition-colors">Our Vision</span>
            <h2 class="text-4xl font-headline font-medium text-on-surface group-hover:text-white transition-colors">Trusted leader in tactical and drone solutions.</h2>
            <p class="text-on-surface-variant leading-relaxed group-hover:text-white/75 transition-colors">To become a trusted leader in tactical, technology-driven, and drone solutions by fostering innovation, promoting sustainable practices, and contributing to India’s self-reliant growth.</p>
          </div>
        </div>
      </section>
      <section class="bg-surface-container-low py-20 md:py-32">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
          <div class="mb-16 md:mb-24 flex flex-col items-center text-center">
            <div class="w-12 h-[2px] bg-primary mb-8"></div>
            <h2 class="text-5xl font-headline font-medium text-on-surface tracking-tight">Our Evolution</h2>
            <p class="mt-6 max-w-3xl text-lg text-on-surface-variant leading-relaxed">Our journey reflects a focused progression from an idea to a mission-driven organization building indigenous, future-ready tactical and drone solutions.</p>
          </div>
          <div class="relative">
            <div class="group grid grid-cols-1 md:grid-cols-12 gap-8 items-start rounded-lg px-4 sm:px-6 py-8 md:px-10 md:py-12 transition-all duration-500 hover:bg-primary">
              <div class="md:col-span-3">
                <span class="text-7xl font-headline font-medium text-primary-container opacity-20 transition-colors duration-500 group-hover:text-white/20">2023</span>
              </div>
              <div class="md:col-span-5">
                <h3 class="text-2xl font-headline font-medium mb-4 transition-colors duration-500 group-hover:text-white">The Idea</h3>
                <p class="text-on-surface-variant leading-relaxed transition-colors duration-500 group-hover:text-white/75">BKT Tactical Solutions began with a clear vision to combine innovation, tactical execution, and national relevance. From the start, the goal was to contribute meaningfully to India’s defence and technology ecosystem with a strong emphasis on self-reliance and sustainability.</p>
              </div>
              <div class="md:col-span-4">
                <ResponsiveImage
                  alt="Close-up of a vintage blueprint on an architect desk with soft natural light coming from a side window"
                  class="w-full h-40 sm:h-48 object-cover rounded-sm grayscale hover:grayscale-0 transition-all duration-700"
                  sizes="(min-width: 768px) 33vw, 100vw"
                  stem="/images/remote/07-4bd1ff6e88"
                />
              </div>
            </div>
            <div class="group grid grid-cols-1 md:grid-cols-12 gap-8 items-start rounded-lg px-4 sm:px-6 py-8 md:px-10 md:py-12 transition-all duration-500 hover:bg-primary mt-12 md:mt-16">
              <div class="md:col-span-3 order-1 md:order-3 text-right">
                <span class="text-7xl font-headline font-medium text-primary-container opacity-20 transition-colors duration-500 group-hover:text-white/20">2024</span>
              </div>
              <div class="md:col-span-4 order-2 md:order-1">
                <ResponsiveImage
                  alt="Team collaborating on tactical technology planning"
                  class="w-full h-40 sm:h-48 object-cover rounded-sm grayscale hover:grayscale-0 transition-all duration-700"
                  sizes="(min-width: 768px) 33vw, 100vw"
                  stem="/images/remote/08-fa52b52484"
                />
              </div>
              <div class="md:col-span-5 order-3 md:order-2">
                <h3 class="text-2xl font-headline font-medium mb-4 transition-colors duration-500 group-hover:text-white">The Team</h3>
                <p class="text-on-surface-variant leading-relaxed transition-colors duration-500 group-hover:text-white/75">With the vision in place, 2024 marked the coming together of a dedicated and skilled team. Built on integrity, execution excellence, and innovation, the team laid the groundwork for technology-driven solutions, including emerging drone applications.</p>
              </div>
            </div>
            <div class="group grid grid-cols-1 md:grid-cols-12 gap-8 items-start rounded-lg px-4 sm:px-6 py-8 md:px-10 md:py-12 transition-all duration-500 hover:bg-primary mt-12 md:mt-16">
              <div class="md:col-span-3">
                <span class="text-7xl font-headline font-medium text-primary-container opacity-20 transition-colors duration-500 group-hover:text-white/20">2025</span>
              </div>
              <div class="md:col-span-5">
                <h3 class="text-2xl font-headline font-medium mb-4 transition-colors duration-500 group-hover:text-white">Establishment</h3>
                <p class="text-on-surface-variant leading-relaxed transition-colors duration-500 group-hover:text-white/75">BKT Tactical Solutions Private Limited was formally established, translating vision into structured operations. This phase focused on building systems, strengthening networks, and aligning the organization with the principles of Make in India while preparing to deliver scalable, high-impact solutions.</p>
              </div>
              <div class="md:col-span-4">
                <ResponsiveImage
                  alt="Drone mission control and tactical deployment planning"
                  class="w-full h-40 sm:h-48 object-cover rounded-sm grayscale hover:grayscale-0 transition-all duration-700"
                  sizes="(min-width: 768px) 33vw, 100vw"
                  stem="/images/remote/09-93c6279c0e"
                />
              </div>
            </div>
            <div class="group grid grid-cols-1 md:grid-cols-12 gap-8 items-start rounded-lg px-6 py-10 md:px-10 md:py-12 transition-all duration-500 hover:bg-primary mt-12 md:mt-16">
              <div class="md:col-span-3 order-1 md:order-3 text-right">
                <span class="text-7xl font-headline font-medium text-primary-container opacity-20 transition-colors duration-500 group-hover:text-white/20">2026</span>
              </div>
              <div class="md:col-span-4 order-2 md:order-1">
                <ResponsiveImage
                  alt="Indigenous drone operations in mountainous terrain"
                  class="w-full h-48 object-cover rounded-sm grayscale hover:grayscale-0 transition-all duration-700"
                  fallback="/images/about-hero-bkt-drone.png"
                  sizes="(min-width: 768px) 33vw, 100vw"
                  stem="/images/about-hero-bkt-drone"
                />
              </div>
              <div class="md:col-span-5 order-3 md:order-2">
                <h3 class="text-2xl font-headline font-medium mb-4 transition-colors duration-500 group-hover:text-white">Building the Future</h3>
                <p class="text-on-surface-variant leading-relaxed transition-colors duration-500 group-hover:text-white/75">Today, we are committed to developing indigenous drone solutions that support India’s defence and tactical technology landscape. With innovation, sustainability, and self-reliance at the core, we are building solutions that are advanced, responsible, and future-ready.</p>
              </div>
            </div>
          </div>
        </div>
      </section>
      <section class="py-20 md:py-32 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 md:gap-12 mb-16 md:mb-24">
            <div class="lg:col-span-5">
              <div class="w-12 h-[2px] bg-primary mb-8"></div>
              <h2 class="text-4xl sm:text-5xl font-headline font-medium text-on-surface tracking-tight mb-6 md:mb-8">The Stewardship</h2>
            </div>
            <div class="lg:col-span-7 flex items-end">
              <p class="text-base sm:text-lg md:text-xl text-on-surface-variant leading-relaxed">Our leadership combines decades of technical mastery with an unwavering commitment to corporate excellence.</p>
            </div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-1px bg-surface-container">
            <div class="group bg-white p-6 sm:p-8 md:p-12 transition-all duration-500 hover:bg-[#1A36B0] hover:-translate-y-1">
              <div class="mb-6 sm:mb-8 overflow-hidden grayscale group-hover:grayscale-0 transition-all duration-500">
                <ResponsiveImage
                  alt="Minimalist professional studio portrait of a woman in a charcoal suit, high-end corporate style, neutral background"
                  class="w-full aspect-square object-cover rounded-full p-2 border border-outline-variant group-hover:border-white/20"
                  sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
                  stem="/images/remote/10-09ae2bf321"
                />
              </div>
              <h3 class="text-2xl font-headline font-medium mb-1 group-hover:text-white">Elena Sterling</h3>
              <p class="text-primary font-medium text-sm tracking-widest uppercase mb-6 group-hover:text-white/80">Chief Executive Officer</p>
              <p class="text-on-surface-variant group-hover:text-white/70 leading-relaxed text-sm">Formerly of Global Systems, Elena leads our long-term strategic vision and governance.</p>
            </div>
            <div class="group bg-white p-6 sm:p-8 md:p-12 transition-all duration-500 hover:bg-[#1A36B0] hover:-translate-y-1">
              <div class="mb-6 sm:mb-8 overflow-hidden grayscale group-hover:grayscale-0 transition-all duration-500">
                <ResponsiveImage
                  alt="Minimalist professional studio portrait of a man in a navy turtleneck, high-end corporate style, neutral background"
                  class="w-full aspect-square object-cover rounded-full p-2 border border-outline-variant group-hover:border-white/20"
                  sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
                  stem="/images/remote/11-9cacf5bd2c"
                />
              </div>
              <h3 class="text-2xl font-headline font-medium mb-1 group-hover:text-white">Marcus Thorne</h3>
              <p class="text-primary font-medium text-sm tracking-widest uppercase mb-6 group-hover:text-white/80">Chief Technology Officer</p>
              <p class="text-on-surface-variant group-hover:text-white/70 leading-relaxed text-sm">A pioneer in distributed systems, Marcus oversees all architectural innovations.</p>
            </div>
            <div class="group bg-white p-6 sm:p-8 md:p-12 transition-all duration-500 hover:bg-[#1A36B0] hover:-translate-y-1">
              <div class="mb-6 sm:mb-8 overflow-hidden grayscale group-hover:grayscale-0 transition-all duration-500">
                <ResponsiveImage
                  alt="Minimalist professional studio portrait of a woman with glasses, high-end corporate style, neutral background"
                  class="w-full aspect-square object-cover rounded-full p-2 border border-outline-variant group-hover:border-white/20"
                  sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
                  stem="/images/remote/12-354c5ebb3f"
                />
              </div>
              <h3 class="text-2xl font-headline font-medium mb-1 group-hover:text-white">Sonia Varma</h3>
              <p class="text-primary font-medium text-sm tracking-widest uppercase mb-6 group-hover:text-white/80">Head of Innovation</p>
              <p class="text-on-surface-variant group-hover:text-white/70 leading-relaxed text-sm">Sonia manages our R&amp;D lab, focusing on emerging informatics and AI integration.</p>
            </div>
          </div>
        </div>
      </section>
      <section class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8 py-20 md:py-32 border-t border-surface-container">
        <div class="flex flex-col md:flex-row justify-between items-center gap-8 md:gap-12">
          <h2 class="text-3xl sm:text-4xl md:text-5xl font-headline font-medium tracking-tight text-center md:text-left">Ready to build the extraordinary?</h2>
          <a class="inline-flex items-center gap-4 bg-primary text-white px-10 py-5 rounded-sm font-medium hover:opacity-90 transition-all group" href="/contact">
            Talk to Our Team
            <Icon class="group-hover:translate-x-1 transition-transform" name="arrow_forward" />
          </a>
        </div>
      </section>
    </main>
    <SiteFooter />
</BaseLayout>
