---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteNav from "../components/SiteNav.astro";
import SiteFooter from "../components/SiteFooter.astro";
import ResponsiveImage from "../components/ResponsiveImage.astro";
---

<BaseLayout
  title="BKT Tactical Solutions | Elevating Aerial Intelligence"
  description="BKT Tactical Solutions Private Limited delivers reliable tactical, drone, and technology-led solutions with a focus on precision, sustainability, and Make in India."
  bodyClass="bg-surface text-on-surface antialiased"
>
  <SiteNav />

  <main>
    <section class="relative h-screen flex items-center overflow-hidden">
      <div class="absolute inset-0">
        <video
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          class="w-full h-full object-cover brightness-[0.65]"
          poster="/images/home-hero-poster.jpg"
        >
          <source src="/videos/home-hero-pexels.mp4" type="video/mp4" />
        </video>
      </div>

      <div class="relative z-10 px-6 md:px-12 max-w-7xl mx-auto w-full">
        <div class="max-w-4xl">
          <h1 class="text-6xl md:text-8xl font-medium text-white leading-[1.05] tracking-tight mb-8 text-shadow-sm reveal">
            Precision. Reliability. Operational excellence.
          </h1>
          <div class="flex flex-col md:flex-row md:items-end gap-12 reveal" style="transition-delay: 200ms;">
            <div class="flex-1">
              <p class="text-lg md:text-xl text-white/90 leading-relaxed mb-10 max-w-xl font-medium">
                Trusted for measurable outcomes, reliable execution, and scalable support across critical sectors.
              </p>
              <div class="flex flex-col sm:flex-row gap-4">
                <a class="bg-white text-on-surface px-8 py-4 rounded-sm font-medium text-sm uppercase tracking-widest hover:bg-slate-100 transition-all btn-interact" href="/about">
                  Get In Touch
                </a>
              </div>
            </div>
            <div class="hidden lg:block w-1/3">
              <p class="text-sm text-white/70 leading-relaxed border-l border-white/30 pl-6">
                BKT Tactical Solutions Private Limited creates dependable solutions for complex requirements, combining execution strength with innovation.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="company" class="py-32 bg-white reveal">
      <div class="px-6 md:px-12 max-w-7xl mx-auto">
        <div class="mb-20">
          <span class="text-primary font-medium text-xs uppercase tracking-widest block mb-4">Our Core Principles</span>
          <h2 class="text-4xl md:text-5xl font-medium tracking-tight max-w-3xl">Built on integrity, precision, and operational excellence.</h2>
          <p class="text-on-surface-variant text-lg font-medium max-w-2xl mt-4">Innovation, Make in India, and sustainability guide every engagement.</p>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-px bg-slate-100 border border-slate-100">
            <div class="p-12 bg-white transition-all duration-300 hover:bg-[#1A36B0] group cursor-default">
              <div class="text-xs font-medium text-primary mb-2 transition-colors duration-300 group-hover:text-white">01 ———</div>
              <h3 class="text-2xl font-medium mb-4 transition-colors duration-300 group-hover:text-white">Innovation</h3>
              <p class="text-on-surface-variant text-sm leading-relaxed font-medium transition-colors duration-300 group-hover:text-white/90">We continuously adopt and integrate modern technologies to enhance efficiency, accuracy, and scalability in our operations.</p>
            </div>
            <div class="p-12 bg-white transition-all duration-300 hover:bg-[#1A36B0] group cursor-default">
              <div class="text-xs font-medium text-primary mb-2 transition-colors duration-300 group-hover:text-white">02 ———</div>
              <h3 class="text-2xl font-medium mb-4 transition-colors duration-300 group-hover:text-white">Make in India</h3>
              <p class="text-on-surface-variant text-sm leading-relaxed font-medium transition-colors duration-300 group-hover:text-white/90">We strengthen domestic capabilities by encouraging local sourcing, indigenous solutions, and self-reliant operational models.</p>
            </div>
            <div class="p-12 bg-white transition-all duration-300 hover:bg-[#1A36B0] group cursor-default">
              <div class="text-xs font-medium text-primary mb-2 transition-colors duration-300 group-hover:text-white">03 ———</div>
              <h3 class="text-2xl font-medium mb-4 transition-colors duration-300 group-hover:text-white">Sustainability</h3>
              <p class="text-on-surface-variant text-sm leading-relaxed font-medium transition-colors duration-300 group-hover:text-white/90">We prioritize environmentally responsible practices, efficient resource utilization, and long-term value creation in all our activities.</p>
            </div>
            <div class="p-12 bg-white transition-all duration-300 hover:bg-[#1A36B0] group cursor-default">
              <div class="text-xs font-medium text-primary mb-2 transition-colors duration-300 group-hover:text-white">04 ———</div>
              <h3 class="text-2xl font-medium mb-4 transition-colors duration-300 group-hover:text-white">Integrity &amp; Compliance</h3>
              <p class="text-on-surface-variant text-sm leading-relaxed font-medium transition-colors duration-300 group-hover:text-white/90">Strict adherence to ethical and regulatory standards across every project.</p>
            </div>
          </div>
          <div class="relative overflow-hidden group">
            <ResponsiveImage
              alt=""
              class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700"
              sizes="(min-width: 1024px) 50vw, 100vw"
              stem="/images/remote/01-6943f5504d"
            />
          </div>
        </div>
      </div>
    </section>

    <section id="solutions" class="py-32 bg-primary text-white reveal" style="background-color: #1A36B0;">
      <div class="px-6 md:px-12 max-w-7xl mx-auto">
        <div class="max-w-6xl mx-auto">
          <div class="p-10 md:p-16 transition-all duration-300 rounded-sm">
            <div class="max-w-3xl mb-10 md:mb-14">
              <span class="text-white/60 font-medium text-xs uppercase tracking-widest block mb-4">What We Do</span>
              <h2 class="text-4xl md:text-5xl font-medium tracking-tight mb-6">Tactical and drone solutions built for measurable execution.</h2>
              <p class="text-lg text-white/80 leading-relaxed max-w-2xl">
                We combine tactical support, deployment capability, and execution discipline to deliver reliable outcomes across complex mission environments.
              </p>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 md:gap-8 mb-14">
              <div class="group bg-white/5 border border-white/10 rounded-sm p-7 md:p-8 min-h-[180px] transition-all duration-300 hover:bg-white hover:border-white">
                <div class="text-xs uppercase tracking-[0.35em] text-white/60 font-medium mb-6 group-hover:text-primary">01</div>
                <div class="text-xl md:text-2xl font-medium leading-tight mb-4 text-white group-hover:text-primary">Tactical Support</div>
                <div class="text-sm md:text-base text-white/70 leading-relaxed max-w-sm group-hover:text-primary/80">Operational support services for mission-critical programs and field requirements.</div>
              </div>
              <div class="group bg-white/5 border border-white/10 rounded-sm p-7 md:p-8 min-h-[180px] transition-all duration-300 hover:bg-white hover:border-white">
                <div class="text-xs uppercase tracking-[0.35em] text-white/60 font-medium mb-6 group-hover:text-primary">02</div>
                <div class="text-xl md:text-2xl font-medium leading-tight mb-4 text-white group-hover:text-primary">Field Deployment</div>
                <div class="text-sm md:text-base text-white/70 leading-relaxed max-w-sm group-hover:text-primary/80">Technology-enabled deployment support built for speed, precision, and adaptability.</div>
              </div>
              <div class="group bg-white/5 border border-white/10 rounded-sm p-7 md:p-8 min-h-[180px] transition-all duration-300 hover:bg-white hover:border-white">
                <div class="text-xs uppercase tracking-[0.35em] text-white/60 font-medium mb-6 group-hover:text-primary">03</div>
                <div class="text-xl md:text-2xl font-medium leading-tight mb-4 text-white group-hover:text-primary">Supply Chain</div>
                <div class="text-sm md:text-base text-white/70 leading-relaxed max-w-sm group-hover:text-primary/80">Vendor coordination and logistics support aligned with project execution timelines.</div>
              </div>
              <div class="group bg-white/5 border border-white/10 rounded-sm p-7 md:p-8 min-h-[180px] transition-all duration-300 hover:bg-white hover:border-white">
                <div class="text-xs uppercase tracking-[0.35em] text-white/60 font-medium mb-6 group-hover:text-primary">04</div>
                <div class="text-xl md:text-2xl font-medium leading-tight mb-4 text-white group-hover:text-primary">Project Delivery</div>
                <div class="text-sm md:text-base text-white/70 leading-relaxed max-w-sm group-hover:text-primary/80">End-to-end execution and on-ground management for scalable outcomes.</div>
              </div>
            </div>
            <div class="flex items-start justify-between gap-8 flex-col lg:flex-row">
              <p class="text-lg text-white/80 leading-relaxed max-w-2xl">
                We deliver high-impact tactical, drone, and technology-driven solutions that combine innovation, precision, and operational reliability for complex mission requirements.
              </p>
              <a class="bg-white text-primary px-10 py-4 rounded-sm font-medium text-sm uppercase tracking-widest hover:bg-slate-100 transition-all border border-transparent btn-interact btn-interact-light inline-flex shrink-0" href="/contact">
                Learn More
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-32 bg-white reveal">
      <div class="px-6 md:px-12 max-w-7xl mx-auto">
        <div class="flex justify-between items-end mb-16">
          <div>
            <span class="text-primary font-medium text-xs uppercase tracking-widest block mb-4">Portfolio</span>
            <h2 class="text-4xl md:text-5xl font-medium tracking-tight">Our Recent Work</h2>
          </div>
          <a class="bg-primary text-white px-8 py-3 rounded-sm font-medium text-sm uppercase tracking-widest hover:bg-opacity-90 transition-all btn-interact btn-interact-light" href="/about">
            View More
          </a>
        </div>
        <div class="space-y-12">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center overflow-hidden cursor-pointer group">
            <div class="p-12 lg:p-16 transition-colors duration-300 hover-card-blue bg-slate-50 border border-slate-100 rounded-sm">
              <span class="text-on-surface-variant/60 group-hover:text-white/60 font-medium text-xs uppercase tracking-widest block mb-4">May 1, 2023</span>
              <h3 class="text-3xl font-medium mb-6 transition-colors duration-300">Aerial Car Photography</h3>
              <p class="text-on-surface-variant group-hover:text-white/80 text-lg leading-relaxed mb-8 max-w-lg transition-colors duration-300">
                This portfolio showcases cars from a unique aerial perspective, captured by drones. It includes shots of cars on the road and in scenic locations.
              </p>
              <a class="inline-flex items-center gap-4 text-sm font-medium uppercase tracking-widest transition-colors duration-300 group-hover:text-white" href="#">
                View More
                <span class="material-symbols-outlined group-hover:translate-x-2 transition-transform">arrow_forward</span>
              </a>
            </div>
            <div class="overflow-hidden h-[400px] lg:h-[500px] rounded-sm">
              <ResponsiveImage
                alt="Aerial Car"
                class="w-full h-full object-cover transition-all duration-700"
                sizes="(min-width: 1024px) 50vw, 100vw"
                stem="/images/remote/02-afcde7f5cb"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center overflow-hidden cursor-pointer group">
            <div class="overflow-hidden h-[400px] lg:h-[500px] rounded-sm lg:order-1 order-2">
              <ResponsiveImage
                alt="Adaptive approach"
                class="w-full h-full object-cover transition-all duration-700"
                sizes="(min-width: 1024px) 50vw, 100vw"
                stem="/images/remote/03-f6a7303e7b"
              />
            </div>
            <div class="p-12 lg:p-16 transition-colors duration-300 hover-card-blue bg-slate-50 border border-slate-100 rounded-sm lg:order-2 order-1">
              <span class="text-on-surface-variant/60 group-hover:text-white/60 font-medium text-xs uppercase tracking-widest block mb-4">April 30, 2023</span>
              <h3 class="text-3xl font-medium mb-6 transition-colors duration-300">Drone Filmography</h3>
              <p class="text-on-surface-variant group-hover:text-white/80 text-lg leading-relaxed mb-8 max-w-lg transition-colors duration-300">
                Drone Filmography highlights the potential of drones to capture stunning footage that allows filmmakers to tell stories in new and innovative ways.
              </p>
              <a class="inline-flex items-center gap-4 text-sm font-medium uppercase tracking-widest transition-colors duration-300 group-hover:text-white" href="#">
                View More
                <span class="material-symbols-outlined group-hover:translate-x-2 transition-transform">arrow_forward</span>
              </a>
            </div>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center overflow-hidden cursor-pointer group">
            <div class="p-12 lg:p-16 transition-colors duration-300 hover-card-blue bg-slate-50 border border-slate-100 rounded-sm">
              <span class="text-on-surface-variant/60 group-hover:text-white/60 font-medium text-xs uppercase tracking-widest block mb-4">April 25, 2023</span>
              <h3 class="text-3xl font-medium mb-6 transition-colors duration-300">Wedding Moments</h3>
              <p class="text-on-surface-variant group-hover:text-white/80 text-lg leading-relaxed mb-8 max-w-lg transition-colors duration-300">
                This portfolio presents a collection of memorable moments from weddings captured by drones. These shots offer a bird's eye view of the special moments.
              </p>
              <a class="inline-flex items-center gap-4 text-sm font-medium uppercase tracking-widest transition-colors duration-300 group-hover:text-white" href="#">
                View More
                <span class="material-symbols-outlined group-hover:translate-x-2 transition-transform">arrow_forward</span>
              </a>
            </div>
            <div class="overflow-hidden h-[400px] lg:h-[500px] rounded-sm">
              <ResponsiveImage
                alt="Wedding Moments"
                class="w-full h-full object-cover transition-all duration-700"
                sizes="(min-width: 1024px) 50vw, 100vw"
                stem="/images/remote/04-77289bfb3e"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="technology" class="relative py-32 overflow-hidden bg-primary text-white reveal" style="background-color: #1A36B0;">
      <div class="px-6 md:px-12 max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
        <div class="relative">
          <div class="absolute -top-10 -left-10 w-40 h-40 bg-white/10 rounded-full blur-[100px] opacity-50"></div>
          <ResponsiveImage
            alt="Abstract cinematic shot of a drone pilot wearing VR goggles looking upwards into a clear blue sky"
            class="rounded-2xl shadow-2xl relative z-10 w-full h-[600px] object-cover border border-white/10"
            sizes="(min-width: 1024px) 50vw, 100vw"
            stem="/images/remote/05-e3eab71c70"
          />
        </div>
        <div>
          <div class="mb-16">
            <h4 class="text-white/60 uppercase tracking-widest font-medium text-sm mb-4">Our Vision</h4>
            <h2 class="text-4xl md:text-5xl font-medium mb-6 tracking-tight">Trusted leader in tactical and technology-driven solutions</h2>
            <p class="text-xl text-white/80 leading-relaxed font-medium">To become a trusted leader in tactical, technology-driven, and drone solutions by fostering innovation, promoting sustainable practices, and contributing to India’s self-reliant growth.</p>
          </div>
          <div>
            <h4 class="text-white/60 uppercase tracking-widest font-medium text-sm mb-4">Our Mission</h4>
            <h2 class="text-4xl md:text-5xl font-medium mb-6 tracking-tight">High-quality execution with indigenous capability</h2>
            <p class="text-xl text-white/80 leading-relaxed font-medium">We deliver high-quality, reliable, and scalable tactical and drone solutions through advanced technology, indigenous capabilities, sustainable operations, and long-term partnerships built on trust and performance.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-32 bg-slate-50 reveal">
      <div class="px-6 md:px-12 max-w-7xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-center">
          <div class="order-2 lg:order-1">
            <div class="mb-16">
              <span class="text-primary font-medium text-xs uppercase tracking-widest block mb-4">New Technology</span>
              <h2 class="text-4xl md:text-5xl font-medium mb-8 tracking-tight">Explore The World From A New Perspective</h2>
              <p class="text-lg text-on-surface-variant leading-relaxed mb-10 font-medium">Unleash your creativity with our drone equipment and services. We provide end-to-end aerial solutions for modern enterprise needs.</p>
              <div class="space-y-6">
                <a class="flex items-center justify-between py-5 px-6 border border-slate-200 group hover-card-blue transition-all duration-300" href="#">
                  <span class="text-lg font-medium transition-colors duration-300">Great Experience</span>
                  <span class="material-symbols-outlined group-hover:translate-x-2 transition-all duration-300">arrow_forward</span>
                </a>
                <a class="flex items-center justify-between py-5 px-6 border border-slate-200 group hover-card-blue transition-all duration-300" href="#">
                  <span class="text-lg font-medium transition-colors duration-300">Remote Control</span>
                  <span class="material-symbols-outlined group-hover:translate-x-2 transition-all duration-300">arrow_forward</span>
                </a>
              </div>
            </div>
          </div>
          <div class="order-1 lg:order-2">
            <ResponsiveImage
              alt=""
              class="w-full h-[600px] object-cover grayscale rounded-sm"
              sizes="(min-width: 1024px) 50vw, 100vw"
              stem="/images/remote/06-bd114049ac"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="py-32 bg-primary text-white text-center relative overflow-hidden reveal" style="background-color: #1A36B0;">
      <div class="absolute inset-0 opacity-10">
        <span class="material-symbols-outlined text-[600px] absolute -top-40 -right-40" data-icon="flight_takeoff">flight_takeoff</span>
      </div>
      <div class="px-6 md:px-12 max-w-4xl mx-auto relative z-10">
        <div class="text-xs font-medium uppercase tracking-[0.4em] mb-10 text-white/60">BKT Tactical Solutions</div>
        <h2 class="text-5xl md:text-7xl font-medium tracking-tight mb-8">Let's cooperate together</h2>
        <p class="text-xl text-white/70 mb-12 max-w-2xl mx-auto font-medium">Experience heightened speed, improved stability, and a complete suite of features for your next aerial mission.</p>
        <button class="bg-white text-primary px-12 py-5 rounded-sm font-medium text-sm uppercase tracking-widest hover:bg-slate-100 transition-all shadow-2xl btn-interact">
                    Get a Free Quote
        </button>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
