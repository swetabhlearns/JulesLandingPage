---
import BaseLayout from "../layouts/BaseLayout.astro";
import homeHeroPoster from "../assets/home-hero-poster.jpg";
import SiteNav from "../components/SiteNav.astro";
import SiteFooter from "../components/SiteFooter.astro";
import Icon from "../components/Icon.astro";
import ResponsiveImage from "../components/ResponsiveImage.astro";
import { homeSchema } from "../lib/schema";
---

<BaseLayout
  title="Heavy Payload UAV Manufacturer India | BKT Tactical Solutions"
  description="BKT Tactical Solutions develops heavy payload UAV platforms, drone logistics support, RTK navigation workflows, and tactical deployment capability in India."
  schema={homeSchema()}
  bodyClass="bg-surface text-on-surface antialiased"
>
  <SiteNav />

  <main>
    <section class="relative min-h-[100svh] md:h-screen flex items-center overflow-hidden">
      <div class="absolute inset-0">
        <video
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          class="w-full h-full object-cover brightness-[0.65]"
          poster={homeHeroPoster.src}
        >
          <source src="/videos/home-hero-pexels.mp4" type="video/mp4" />
        </video>
      </div>

      <div class="relative z-10 px-4 sm:px-6 md:px-12 max-w-7xl mx-auto w-full">
        <div class="max-w-4xl">
          <h1 class="text-4xl sm:text-5xl md:text-8xl font-medium text-white leading-[1.05] tracking-tight mb-6 md:mb-8 text-shadow-sm reveal">
            Heavy payload UAV platforms built in India.
          </h1>
          <div class="flex flex-col md:flex-row md:items-end gap-8 md:gap-12 reveal" style="transition-delay: 200ms;">
            <div class="flex-1">
              <p class="text-base sm:text-lg md:text-xl text-white/90 leading-relaxed mb-8 md:mb-10 max-w-xl font-medium">
                Trishul Series drones support 10kg, 16kg, and 30kg payload missions with RTK navigation, autonomous mission capability, and field-ready deployment support.
              </p>
              <div class="flex flex-col sm:flex-row gap-4">
                <a class="bg-white text-on-surface px-8 py-4 rounded-sm font-medium text-sm uppercase tracking-widest hover:bg-slate-100 transition-all btn-interact inline-flex justify-center w-full sm:w-auto" href="/contact/">
                  Discuss UAV Requirement
                </a>
                <a class="border border-white/40 text-white px-8 py-4 rounded-sm font-medium text-sm uppercase tracking-widest hover:bg-white/10 transition-all btn-interact inline-flex justify-center w-full sm:w-auto" href="/products/">
                  View Trishul Series
                </a>
              </div>
            </div>
            <div class="hidden lg:block w-1/3">
              <p class="text-sm text-white/70 leading-relaxed border-l border-white/30 pl-6">
                BKT Tactical Solutions Private Limited develops UAV and tactical technology capability for logistics, surveillance, emergency response, and complex field requirements.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="company" class="py-20 md:py-32 bg-white reveal">
      <div class="px-4 sm:px-6 md:px-12 max-w-7xl mx-auto">
        <div class="mb-20">
          <span class="text-primary font-medium text-xs uppercase tracking-widest block mb-4">Our Core Principles</span>
          <h2 class="text-4xl md:text-5xl font-medium tracking-tight max-w-3xl">Indian UAV capability for payload-led field operations.</h2>
          <p class="text-on-surface-variant text-lg font-medium max-w-2xl mt-4">Innovation, Make in India, maintainability, and responsible deployment guide every UAV engagement.</p>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-px bg-slate-100 border border-slate-100">
            <div class="p-12 bg-white transition-all duration-300 hover:bg-[#1A36B0] group cursor-default">
              <div class="text-xs font-medium text-primary mb-2 transition-colors duration-300 group-hover:text-white">01 ———</div>
              <h3 class="text-2xl font-medium mb-4 transition-colors duration-300 group-hover:text-white">Innovation</h3>
              <p class="text-on-surface-variant text-sm leading-relaxed font-medium transition-colors duration-300 group-hover:text-white/90">We continuously adopt and integrate modern technologies to enhance efficiency, accuracy, and scalability in our operations.</p>
            </div>
            <div class="p-12 bg-white transition-all duration-300 hover:bg-[#1A36B0] group cursor-default">
              <div class="text-xs font-medium text-primary mb-2 transition-colors duration-300 group-hover:text-white">02 ———</div>
              <h3 class="text-2xl font-medium mb-4 transition-colors duration-300 group-hover:text-white">Make in India</h3>
              <p class="text-on-surface-variant text-sm leading-relaxed font-medium transition-colors duration-300 group-hover:text-white/90">We strengthen domestic capabilities by encouraging local sourcing, indigenous solutions, and self-reliant operational models.</p>
            </div>
            <div class="p-12 bg-white transition-all duration-300 hover:bg-[#1A36B0] group cursor-default">
              <div class="text-xs font-medium text-primary mb-2 transition-colors duration-300 group-hover:text-white">03 ———</div>
              <h3 class="text-2xl font-medium mb-4 transition-colors duration-300 group-hover:text-white">Sustainability</h3>
              <p class="text-on-surface-variant text-sm leading-relaxed font-medium transition-colors duration-300 group-hover:text-white/90">We prioritize environmentally responsible practices, efficient resource utilization, and long-term value creation in all our activities.</p>
            </div>
            <div class="p-12 bg-white transition-all duration-300 hover:bg-[#1A36B0] group cursor-default">
              <div class="text-xs font-medium text-primary mb-2 transition-colors duration-300 group-hover:text-white">04 ———</div>
              <h3 class="text-2xl font-medium mb-4 transition-colors duration-300 group-hover:text-white">Integrity &amp; Compliance</h3>
              <p class="text-on-surface-variant text-sm leading-relaxed font-medium transition-colors duration-300 group-hover:text-white/90">Strict adherence to ethical and regulatory standards across every project.</p>
            </div>
          </div>
          <div class="relative overflow-hidden group">
            <ResponsiveImage
              alt="Industrial UAV operations supporting heavy payload drone missions in India"
              class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700"
              sizes="(min-width: 1024px) 50vw, 100vw"
              stem="/images/remote/01-6943f5504d"
            />
          </div>
        </div>
      </div>
    </section>

    <section id="solutions" class="py-20 md:py-32 bg-primary text-white reveal" style="background-color: #1A36B0;">
      <div class="px-4 sm:px-6 md:px-12 max-w-7xl mx-auto">
        <div class="max-w-6xl mx-auto">
          <div class="p-6 sm:p-8 md:p-16 transition-all duration-300 rounded-sm">
            <div class="max-w-3xl mb-10 md:mb-14">
              <span class="text-white/60 font-medium text-xs uppercase tracking-widest block mb-4">What We Do</span>
              <h2 class="text-4xl md:text-5xl font-medium tracking-tight mb-6">Drone logistics and tactical UAV solutions built for measurable execution.</h2>
              <p class="text-lg text-white/80 leading-relaxed max-w-2xl">
                We combine heavy payload drone platforms, tactical support, deployment capability, and execution discipline for complex mission environments in India.
              </p>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 md:gap-8 mb-14">
              <div class="group bg-white/5 border border-white/10 rounded-sm p-7 md:p-8 min-h-[180px] transition-all duration-300 hover:bg-white hover:border-white">
                <div class="text-xs uppercase tracking-[0.35em] text-white/60 font-medium mb-6 group-hover:text-primary/80">01</div>
                <div class="text-xl md:text-2xl font-medium leading-tight mb-4 text-white group-hover:text-primary">Tactical UAV Support</div>
                <div class="text-sm md:text-base text-white/70 leading-relaxed max-w-sm group-hover:text-primary/80">Operational support for mission-critical UAV programs, payload planning, and field requirements.</div>
              </div>
              <div class="group bg-white/5 border border-white/10 rounded-sm p-7 md:p-8 min-h-[180px] transition-all duration-300 hover:bg-white hover:border-white">
                <div class="text-xs uppercase tracking-[0.35em] text-white/60 font-medium mb-6 group-hover:text-primary/80">02</div>
                <div class="text-xl md:text-2xl font-medium leading-tight mb-4 text-white group-hover:text-primary">Field Deployment</div>
                <div class="text-sm md:text-base text-white/70 leading-relaxed max-w-sm group-hover:text-primary/80">Technology-enabled UAV deployment support built for speed, precision, and adaptability.</div>
              </div>
              <div class="group bg-white/5 border border-white/10 rounded-sm p-7 md:p-8 min-h-[180px] transition-all duration-300 hover:bg-white hover:border-white">
                <div class="text-xs uppercase tracking-[0.35em] text-white/60 font-medium mb-6 group-hover:text-primary/80">03</div>
                <div class="text-xl md:text-2xl font-medium leading-tight mb-4 text-white group-hover:text-primary">Drone Logistics</div>
                <div class="text-sm md:text-base text-white/70 leading-relaxed max-w-sm group-hover:text-primary/80">Payload movement, vendor coordination, and route planning aligned with project execution timelines.</div>
              </div>
              <div class="group bg-white/5 border border-white/10 rounded-sm p-7 md:p-8 min-h-[180px] transition-all duration-300 hover:bg-white hover:border-white">
                <div class="text-xs uppercase tracking-[0.35em] text-white/60 font-medium mb-6 group-hover:text-primary/80">04</div>
                <div class="text-xl md:text-2xl font-medium leading-tight mb-4 text-white group-hover:text-primary">Project Delivery</div>
                <div class="text-sm md:text-base text-white/70 leading-relaxed max-w-sm group-hover:text-primary/80">End-to-end execution and on-ground management for scalable outcomes.</div>
              </div>
            </div>
            <div class="flex items-start justify-between gap-8 flex-col lg:flex-row">
              <p class="text-lg text-white/80 leading-relaxed max-w-2xl">
                We deliver high-impact tactical, drone, and technology-driven solutions that combine indigenous capability, precision, and operational reliability for complex mission requirements.
              </p>
                <a class="bg-white text-primary px-10 py-4 rounded-sm font-medium text-sm uppercase tracking-widest hover:bg-slate-100 transition-all border border-transparent btn-interact btn-interact-light inline-flex shrink-0 justify-center w-full sm:w-auto" href="/solutions/">
                Explore UAV Solutions
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="trishul-series" class="py-24 bg-white reveal">
      <div class="px-4 sm:px-6 md:px-12 max-w-7xl mx-auto">
        <div class="text-center mb-12 max-w-3xl mx-auto">
          <span class="text-primary font-medium text-xs uppercase tracking-widest block mb-4">Product Series</span>
          <h2 class="text-4xl md:text-6xl font-medium tracking-tight mb-6">Trishul Series: Heavy Payload UAV Platforms</h2>
          <p class="text-xl text-primary/80 font-medium italic">Precision. Power. Reliability.</p>
          <div class="mt-10 max-w-3xl mx-auto">
            <p class="text-lg text-on-surface-variant leading-relaxed">
              Built for demanding operational environments, all Trishul variants share a unified flight stack and modular architecture, keeping deployment scalable and maintenance straightforward.
            </p>
          </div>
        </div>

        <div class="mb-20 rounded-sm border border-slate-100 bg-slate-950 overflow-hidden shadow-2xl">
          <div class="grid grid-cols-1 lg:grid-cols-12">
            <div class="lg:col-span-8 relative">
              <video
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
                poster="/media/trishul/trishul-frame-02.jpg"
                class="w-full h-[280px] sm:h-[360px] lg:h-[460px] object-cover brightness-[0.8]"
              >
                <source src="/media/trishul/trishul-demo.mp4" type="video/mp4" />
              </video>
              <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/35 to-transparent"></div>
            </div>
            <div class="lg:col-span-4 p-6 sm:p-8 md:p-10 flex flex-col justify-between gap-8 bg-slate-950 text-white">
              <div>
                <span class="text-white/60 text-xs uppercase tracking-[0.35em] font-medium block mb-4">Live Flight Reel</span>
                <h3 class="text-2xl sm:text-3xl font-medium tracking-tight mb-4">Trishul in motion, under load.</h3>
                <p class="text-white/75 text-sm sm:text-base leading-relaxed max-w-sm">
                  Test footage from field trials, showing payload-led UAV movement, stability, and mission readiness.
                </p>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                <div class="rounded-sm border border-white/15 bg-white/5 px-4 py-3 text-sm text-white/80">Autonomous mission stack</div>
                <div class="rounded-sm border border-white/15 bg-white/5 px-4 py-3 text-sm text-white/80">RTK navigation</div>
                <div class="rounded-sm border border-white/15 bg-white/5 px-4 py-3 text-sm text-white/80 sm:col-span-2">Modular payload support and fail-safe systems</div>
              </div>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-20">
          <article class="p-10 border border-slate-100 bg-slate-50 rounded-sm hover-card-blue group transition-all duration-300">
            <div class="text-xs font-medium text-primary mb-6 transition-colors duration-300 group-hover:text-white/60 uppercase tracking-widest">Agile Logistics</div>
            <h3 class="text-3xl font-medium mb-4 transition-colors duration-300 group-hover:text-white">10 KG Configuration</h3>
            <ul class="space-y-4 text-sm text-on-surface-variant transition-colors duration-300 group-hover:text-white/90 font-medium">
              <li class="flex items-center gap-2"><Icon class="shrink-0" name="bolt" size={16} /> Hexacopter with X6+ Motor</li>
              <li class="flex items-center gap-2"><Icon class="shrink-0" name="schedule" size={16} /> 25 - 40 Minutes Endurance</li>
              <li class="flex items-center gap-2"><Icon class="shrink-0" name="precision_manufacturing" size={16} /> Light Logistics &amp; Surveillance Ready</li>
            </ul>
            <a class="inline-flex items-center gap-2 mt-8 text-primary group-hover:text-white" href="/products/trishul-10kg/">Explore 10kg UAV <Icon name="arrow_forward" size={16} /></a>
          </article>

          <article class="p-10 border border-slate-100 bg-slate-50 rounded-sm hover-card-blue group transition-all duration-300">
            <div class="text-xs font-medium text-primary mb-6 transition-colors duration-300 group-hover:text-white/60 uppercase tracking-widest">Industrial Standard</div>
            <h3 class="text-3xl font-medium mb-4 transition-colors duration-300 group-hover:text-white">16 KG Configuration</h3>
            <ul class="space-y-4 text-sm text-on-surface-variant transition-colors duration-300 group-hover:text-white/90 font-medium">
              <li class="flex items-center gap-2"><Icon class="shrink-0" name="settings_input_component" size={16} /> Hexacopter with X8+ Motor</li>
              <li class="flex items-center gap-2"><Icon class="shrink-0" name="schedule" size={16} /> 30 - 50 Minutes Endurance</li>
              <li class="flex items-center gap-2"><Icon class="shrink-0" name="package" size={16} /> Tactical Payload Integration</li>
            </ul>
            <a class="inline-flex items-center gap-2 mt-8 text-primary group-hover:text-white" href="/products/trishul-16kg/">Explore 16kg UAV <Icon name="arrow_forward" size={16} /></a>
          </article>

          <article class="p-10 border border-slate-100 bg-slate-50 rounded-sm hover-card-blue group transition-all duration-300">
            <div class="text-xs font-medium text-primary mb-6 transition-colors duration-300 group-hover:text-white/60 uppercase tracking-widest">Extreme Capacity</div>
            <h3 class="text-3xl font-medium mb-4 transition-colors duration-300 group-hover:text-white">30 KG Configuration</h3>
            <ul class="space-y-4 text-sm text-on-surface-variant transition-colors duration-300 group-hover:text-white/90 font-medium">
              <li class="flex items-center gap-2"><Icon class="shrink-0" name="moped" size={16} /> Quadcopter with X11+ Motor</li>
              <li class="flex items-center gap-2"><Icon class="shrink-0" name="schedule" size={16} /> 45 - 60 Minutes Endurance</li>
              <li class="flex items-center gap-2"><Icon class="shrink-0" name="construction" size={16} /> Heavy Logistics &amp; Emergency Response</li>
            </ul>
            <a class="inline-flex items-center gap-2 mt-8 text-primary group-hover:text-white" href="/products/trishul-30kg/">Explore 30kg UAV <Icon name="arrow_forward" size={16} /></a>
          </article>
        </div>

        <div class="border-t border-slate-100 pt-16">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
            <div>
              <h4 class="text-sm font-medium uppercase tracking-widest text-primary mb-6">Standard Features</h4>
              <p class="text-on-surface-variant text-sm leading-relaxed font-medium">
                Every Trishul airframe comes standard with a robust avionics package and mission-ready safety systems.
              </p>
            </div>
            <div class="md:col-span-2 grid grid-cols-1 sm:grid-cols-2 gap-8">
              <div class="flex gap-4">
                <Icon class="text-primary shrink-0" name="memory" size={20} />
                <div>
                  <div class="font-medium mb-1">Advanced Flight Controller</div>
                  <div class="text-xs text-on-surface-variant">Autonomous mission capability with stable heavy-lift performance.</div>
                </div>
              </div>
              <div class="flex gap-4">
                <Icon class="text-primary shrink-0" name="location_searching" size={20} />
                <div>
                  <div class="font-medium mb-1">RTK Navigation</div>
                  <div class="text-xs text-on-surface-variant">Centimeter-level positioning accuracy for high-precision missions.</div>
                </div>
              </div>
              <div class="flex gap-4">
                <Icon class="text-primary shrink-0" name="shield_with_heart" size={20} />
                <div>
                  <div class="font-medium mb-1">Safety Systems</div>
                  <div class="text-xs text-on-surface-variant">Multi-layer fail-safes and reliable mission protection.</div>
                </div>
              </div>
              <div class="flex gap-4">
                <Icon class="text-primary shrink-0" name="encrypted" size={20} />
                <div>
                  <div class="font-medium mb-1">Encrypted Datalink</div>
                  <div class="text-xs text-on-surface-variant">Secure communications for sensitive operational data.</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
    <section id="technology" class="relative py-20 md:py-32 overflow-hidden bg-primary text-white reveal" style="background-color: #1A36B0;">
      <div class="px-4 sm:px-6 md:px-12 max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="relative">
          <div class="absolute -top-10 -left-10 w-40 h-40 bg-white/10 rounded-full blur-[100px] opacity-50"></div>
          <ResponsiveImage
            alt="Abstract cinematic shot of a drone pilot wearing VR goggles looking upwards into a clear blue sky"
            class="rounded-2xl shadow-2xl relative z-10 w-full h-[320px] sm:h-[420px] lg:h-[600px] object-cover border border-white/10"
            sizes="(min-width: 1024px) 50vw, 100vw"
            stem="/images/remote/05-e3eab71c70"
          />
        </div>
        <div>
          <div class="mb-16">
            <span class="block text-white/60 uppercase tracking-widest font-medium text-sm mb-4">Our Vision</span>
              <h2 class="text-4xl md:text-5xl font-medium mb-6 tracking-tight">Trusted leader in tactical and technology-driven solutions</h2>
            <p class="text-base sm:text-lg md:text-xl text-white/80 leading-relaxed font-medium">To become a trusted leader in tactical, technology-driven, and drone solutions by fostering innovation, promoting sustainable practices, and contributing to India’s self-reliant growth.</p>
          </div>
          <div>
            <span class="block text-white/60 uppercase tracking-widest font-medium text-sm mb-4">Our Mission</span>
              <h2 class="text-4xl md:text-5xl font-medium mb-6 tracking-tight">High-quality execution with indigenous capability</h2>
            <p class="text-base sm:text-lg md:text-xl text-white/80 leading-relaxed font-medium">We deliver high-quality, reliable, and scalable tactical and drone solutions through advanced technology, indigenous capabilities, sustainable operations, and long-term partnerships built on trust and performance.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 md:py-32 bg-slate-50 reveal">
      <div class="px-4 sm:px-6 md:px-12 max-w-7xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 items-center">
          <div class="order-2 lg:order-1">
            <div class="mb-16">
              <span class="text-primary font-medium text-xs uppercase tracking-widest block mb-4">New Technology</span>
            <h2 class="text-4xl md:text-5xl font-medium mb-8 tracking-tight">Explore The World From A New Perspective</h2>
              <p class="text-base sm:text-lg text-on-surface-variant leading-relaxed mb-10 font-medium">Unleash your creativity with our drone equipment and services. We provide end-to-end aerial solutions for modern enterprise needs.</p>
              <div class="space-y-6">
                <a class="flex items-center justify-between py-5 px-6 border border-slate-200 group hover-card-blue transition-all duration-300" href="/about/">
                  <span class="text-lg font-medium transition-colors duration-300">Indian UAV capability</span>
                  <Icon class="group-hover:translate-x-2 transition-all duration-300" name="arrow_forward" />
                </a>
                <a class="flex items-center justify-between py-5 px-6 border border-slate-200 group hover-card-blue transition-all duration-300" href="/contact/">
                  <span class="text-lg font-medium transition-colors duration-300">Direct UAV enquiry</span>
                  <Icon class="group-hover:translate-x-2 transition-all duration-300" name="arrow_forward" />
                </a>
              </div>
            </div>
          </div>
          <div class="order-1 lg:order-2">
            <ResponsiveImage
              alt="Heavy payload UAV planning for drone logistics and tactical deployment"
              class="w-full h-[320px] sm:h-[420px] lg:h-[600px] object-cover grayscale rounded-sm"
              sizes="(min-width: 1024px) 50vw, 100vw"
              stem="/images/remote/06-bd114049ac"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 md:py-32 bg-primary text-white text-center relative overflow-hidden reveal" style="background-color: #1A36B0;">
      <div class="absolute inset-0 opacity-10">
        <Icon class="text-[600px] absolute -top-40 -right-40" name="flight_takeoff" />
      </div>
      <div class="px-4 sm:px-6 md:px-12 max-w-4xl mx-auto relative z-10">
        <div class="text-xs font-medium uppercase tracking-[0.4em] mb-10 text-white/60">BKT Tactical Solutions</div>
        <h2 class="text-4xl sm:text-5xl md:text-7xl font-medium tracking-tight mb-8">Plan your next UAV mission.</h2>
        <p class="text-base sm:text-lg md:text-xl text-white/70 mb-12 max-w-2xl mx-auto font-medium">Share your payload, route, deployment environment, and operational constraints with the BKT Tactical team.</p>
        <a class="bg-white text-primary px-12 py-5 rounded-sm font-medium text-sm uppercase tracking-widest hover:bg-slate-100 transition-all shadow-2xl btn-interact inline-flex w-full sm:w-auto justify-center" href="/contact/">
          Start Project Discussion
        </a>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
