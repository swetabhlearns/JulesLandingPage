---
import "../styles/global.css";
import { ViewTransitions } from "astro:transitions";
import { siteUrl } from "../lib/seo-data";
const {
  title,
  description = "",
  canonical,
  ogImage,
  schema = [],
  bodyClass = "",
  htmlClass = "scroll-smooth",
} = Astro.props;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).href;
const siteName = "BKT Tactical Solutions";
const logoUrl = new URL("/images/bkt-logo-mark.svg", siteUrl).href;
const ogImageUrl = ogImage ?? new URL("/images/og-home.png", siteUrl).href;
const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID ?? "G-H7BQYR81SD";
const baseSchemas = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": `${siteUrl}#organization`,
    name: "BKT Tactical Solutions Private Limited",
    alternateName: siteName,
    url: siteUrl,
    logo: logoUrl,
    image: logoUrl,
    email: "info.tactical@bktcorp.com",
    areaServed: "IN",
    sameAs: ["https://www.linkedin.com/company/bkt-tactical/"],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${siteUrl}#website`,
    name: siteName,
    url: siteUrl,
    description,
    inLanguage: "en",
  },
];
const normalizedSchema = Array.isArray(schema) ? schema : [schema];
const graph = [...baseSchemas, ...normalizedSchema].filter(Boolean);
const jsonLd = graph.length > 0 ? { "@context": "https://schema.org", "@graph": graph } : null;
---

<!doctype html>
<html lang="en" class={htmlClass}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <link rel="icon" href="/images/bkt-logo-mark.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/images/bkt-logo-mark-192.png" />
    <meta property="og:title" content={title} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    {description && <meta property="og:description" content={description} />}
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImageUrl} />
    <ViewTransitions />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    {
      gaMeasurementId && (
        <>
          <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`} />
          <script
            is:inline
            define:vars={{ gaMeasurementId }}
            set:html={`window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag("js", new Date());
gtag("config", gaMeasurementId);`}
          />
        </>
      )
    }
    <slot name="head" />
  </head>
  <body class={bodyClass}>
    <slot />
    <script is:inline>
      let observer;

      const initReveal = () => {
        observer?.disconnect();

        const revealCallback = (entries, currentObserver) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("active");
              currentObserver.unobserve(entry.target);
            }
          });
        };

        observer = new IntersectionObserver(revealCallback, {
          threshold: 0.1,
        });

        document.querySelectorAll(".reveal").forEach((el) => {
          observer.observe(el);
        });
      };

      document.addEventListener("astro:page-load", initReveal);
      initReveal();
    </script>
  </body>
</html>
